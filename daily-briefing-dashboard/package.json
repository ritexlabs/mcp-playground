{
  "name": "my-daily-briefing",
  "version": "2.0.0",
  "description": "Personalized day briefing dashboard — React + Tailwind + MCP gateway",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start":       "node server.js",
    "build":       "vite build",
    "preview":     "vite preview --port 8080",
    "dev:api":     "node server.js",
    "dev:ui":      "vite --port 5173",
    "dev":         "node server.js & vite --port 5173"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "cors":     "^2.8.5",
    "dotenv":   "^16.4.5",
    "express":  "^4.19.2",
    "react":    "^18.3.1",
    "react-dom":"^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer":         "^10.4.20",
    "postcss":              "^8.4.47",
    "tailwindcss":          "^3.4.14",
    "vite":                 "^5.4.10"
  }
}
