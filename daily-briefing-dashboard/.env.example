# Daily Briefing Dashboard — Configuration
# Copy to .env and fill in values.
# ⚠️  NEVER commit .env to version control.

# ============================================================================
# SERVER
# ============================================================================
PORT=8080

# ============================================================================
# MCP GATEWAY URL
# The Python FastAPI gateway must be running before starting the dashboard.
# Default assumes it is running locally on port 8000.
# ============================================================================
MCP_GATEWAY_URL=http://127.0.0.1:8000
