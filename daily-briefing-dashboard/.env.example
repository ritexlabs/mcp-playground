# Daily Briefing Dashboard — Configuration Example
# Copy to .env and fill in your values.
# ⚠️  NEVER commit .env to version control.

# ============================================================================
# SERVER
# ============================================================================
# Port the dashboard Express server listens on.
PORT=8080

# ============================================================================
# MCP GATEWAY
# ============================================================================
# Full URL of the running MCP Gateway.
# The gateway must be started before the dashboard.
MCP_GATEWAY_URL=http://127.0.0.1:8000

# ============================================================================
# SECURITY
# ============================================================================
# Allowed CORS origin for the dashboard (must match the URL you open in browser).
# Must also match DASHBOARD_ORIGIN in mcp-gateway/.env.
DASHBOARD_ORIGIN=http://localhost:8080

# ============================================================================
# LLM — AI Wish Generation (optional)
# ============================================================================
# Provider: openai | anthropic | custom
# When set, the server uses these as the fallback if no model is configured
# in the browser Settings → AI tab.
LLM_PROVIDER=openai

# API key for the chosen provider.
LLM_API_KEY=

# Model name. Defaults: openai → gpt-4o-mini, anthropic → claude-haiku-4-5-20251001
LLM_MODEL=gpt-4o-mini

# Base URL — required only for custom (OpenAI-compatible) providers.
# Examples: http://localhost:11434/v1  (Ollama)
#           http://localhost:1234/v1   (LM Studio)
LLM_BASE_URL=
