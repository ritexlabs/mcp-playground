# MCP Gateway Configuration — Example
# Copy to .env and fill in your values.
# ⚠️  NEVER commit .env to version control.

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
# Options: debug, info, warn, error

# ============================================================================
# GOOGLE OAUTH CREDENTIALS
# ============================================================================
# One OAuth app covers Gmail + Calendar + Drive + Sheets — same Client ID & Secret.
#
# Setup (one-time):
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Desktop application)
#   3. Enable these APIs in your project:
#        • Gmail API
#        • Google Calendar API
#        • Google Drive API
#        • Google Sheets API
#   4. Copy Client ID and Secret below
#   5. Run:  python scripts/auth_all.py
#      (opens browser — tick ALL checkboxes on the consent screen)

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# ============================================================================
# GOOGLE OAUTH TOKEN  (auto-populated by scripts/auth_all.py — do not edit)
# Covers: gmail.readonly + calendar.readonly + drive.readonly + spreadsheets.readonly
# ============================================================================
GOOGLE_OAUTH_TOKEN=

# ============================================================================
# MYSTOCKS SPREADSHEET  (optional)
# ============================================================================
# Share a Google Sheet with your OAuth user and paste the spreadsheet ID here.
# The ID is the long string in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
MYSTOCKS_SPREADSHEET_ID=
MYSTOCKS_RANGE=A:Z

# ============================================================================
# GITHUB CONFIGURATION  (optional)
# ============================================================================
# Personal access token — only needed if you enable GitHub tools.
# Create at https://github.com/settings/tokens  (read:user, repo scopes)
GITHUB_TOKEN=
GITHUB_USERNAME=

# ============================================================================
# INDMONEY MCP  (downstream MCP server, OAuth 2.1 + PKCE)
# ============================================================================
# The gateway proxies all IndMoney tools through its own SSE endpoint.
# No developer registration needed — the gateway self-registers via OAuth dynamic
# client registration (RFC 7591) on first connect.
#
# One-time setup:
#   1. Start the gateway (no extra config needed here)
#   2. Open dashboard → Settings → IndMoney → click "Connect IndMoney"
#   3. Log in with your IndMoney mobile number, OTP, and MPIN in the browser
#   4. Token is stored in macOS Keychain automatically
INDMONEY_MCP_URL=https://mcp.indmoney.com/mcp
INDMONEY_SCOPES=portfolio:read market:read
# Auto-populated by the gateway — do not edit manually
INDMONEY_CLIENT_ID=
INDMONEY_CLIENT_SECRET=
INDMONEY_OAUTH_TOKEN=
# Tool name (without the indmoney_ prefix) to display on the dashboard card.
# e.g. networth_snapshot  (discover available tools in Settings → IndMoney once connected)
INDMONEY_DISPLAY_TOOL=

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
MCP_SERVER_NAME=personal-secure-gateway
MCP_SERVER_VERSION=1.0.0
MCP_HOST=127.0.0.1
MCP_PORT=8000

# ============================================================================
# GATEWAY API TOKEN  (authenticates the daily briefing dashboard)
# ============================================================================
# Auto-generated on first gateway startup if not set.
# Copy the printed token into daily-briefing-dashboard/.env as GATEWAY_API_TOKEN=<value>
# Rotate via Gateway Dashboard → API Token → Rotate Token
GATEWAY_API_TOKEN=

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
TOKEN_EXPIRY_WARNING_HOURS=24

# Origin of the dashboard UI — used for CORS and postMessage target.
# Change this if the dashboard runs on a different host or port.
DASHBOARD_ORIGIN=http://localhost:8080

# Seconds an OAuth state token remains valid (default: 5 minutes).
AUTH_FLOW_TTL_SECONDS=300

# ============================================================================
# QUICK START GUIDE
# ============================================================================
#
# Step 1 — Google Cloud Console (one-time setup)
#   a. Go to https://console.cloud.google.com
#   b. Create a project → APIs & Services → Enable APIs:
#        Gmail API, Google Calendar API, Google Drive API, Google Sheets API
#   c. Credentials → Create OAuth 2.0 Client ID (Desktop app)
#   d. Copy Client ID and Secret into GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
#
# Step 2 — Install and set up
#   python mcp_gateway.py setup
#
# Step 3 — Authenticate all Google services in one browser flow
#   python scripts/auth_all.py
#   • Browser opens → sign in → tick ALL permission checkboxes → Allow
#   • Saves GOOGLE_OAUTH_TOKEN to .env & macOS Keychain
#   • Never need to re-auth unless you revoke at myaccount.google.com/permissions
#
# Step 4 — Start the gateway
#   python mcp_gateway.py start
#
# Step 5 — Start the daily dashboard
#   cd ../daily-briefing-dashboard && python daily_dashboard.py start
#
# ============================================================================
# ============================================================================
# WHATSAPP BUSINESS API (optional)
# ============================================================================
# Get these from https://developers.facebook.com → your WhatsApp app.
# See Settings → WhatsApp in the dashboard for the full setup guide.

# Permanent System User token (never expires, recommended over temporary tokens).
# In Meta Developer Console → WhatsApp → API Setup → generate or copy the token.
WHATSAPP_ACCESS_TOKEN=

# ⚠️  CRITICAL — READ THIS CAREFULLY:
# There are TWO phone numbers visible in the Meta Developer Console:
#
#   1. TEST number  (e.g. +1 555-649-2367) — shown in "Step 1: Try it out"
#      This is Meta's shared sandbox number. Its Phone Number ID appears on
#      that same Step 1 panel. DO NOT use this ID here — it has hard delivery
#      restrictions and cannot send messages to real WhatsApp users outside
#      the allowed-recipients list (Meta error code 131047).
#
#   2. YOUR registered number  (e.g. +91 83105 60360) — shown in "Step 2:
#      Send a message from your registered number"
#      This is the business number you added and verified with your own OTP.
#      Use the Phone Number ID for THIS number.
#
# How to find the correct ID:
#   Meta Developer Console → WhatsApp → API Setup → "Step 2: Send a message
#   from your registered number" → select your number from the dropdown →
#   the Phone Number ID is displayed below the dropdown or in the URL params.
#   It is a long numeric string (e.g. 1087212707818326).
WHATSAPP_PHONE_NUMBER_ID=

# Any string you choose — must match exactly what you enter in Meta's webhook console
WHATSAPP_VERIFY_TOKEN=

# Domain (or subdomain) used for the Cloudflare Tunnel that exposes the webhook endpoint.
# With your own domain: webhook.yourdomain.com
# With Cloudflare quick tunnel: abc.trycloudflare.com  (changes on restart)
# The webhook URL will be: https://<WHATSAPP_WEBHOOK_DOMAIN>/webhook/whatsapp
WHATSAPP_WEBHOOK_DOMAIN=

# ============================================================================
# CLOUDFLARE NAMED TUNNEL  (optional — for stable custom-domain webhooks)
# ============================================================================
# When set, the gateway runs: cloudflared tunnel run --url http://localhost:<port> <name>
# This requires a pre-created named tunnel and a DNS CNAME already configured.
#
# One-time setup:
#   1. cloudflared login
#   2. cloudflared tunnel create whatsapp
#   3. cloudflared tunnel route dns whatsapp <WHATSAPP_WEBHOOK_DOMAIN>
#   4. Paste the tunnel ID (or name) below
#
# When unset, falls back to --hostname <WHATSAPP_WEBHOOK_DOMAIN> if set,
# or a random trycloudflare.com quick-tunnel URL.
CLOUDFLARE_TUNNEL_NAME=